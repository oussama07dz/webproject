  "constraints": [
    {
      "conname": "uploads_id_not_null",
      "contype": "n",
      "remote_table": "-"
    },
    {
      "conname": "uploads_filename_not_null",
      "contype": "n",
      "remote_table": "-"
    },
    {
      "conname": "uploads_original_name_not_null",
      "contype": "n",
      "remote_table": "-"
    },
    {
      "conname": "uploads_pkey",
      "contype": "p",
      "remote_table": "-"
    },
    {
      "conname": "uploads_answer_id_fkey",
      "contype": "f",
      "remote_table": "???"
    }
  ]
}